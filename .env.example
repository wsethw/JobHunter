# Application
APP_ENV=local
LOG_LEVEL=INFO
LOG_DIR=logs
TIMEZONE=America/Sao_Paulo

# Celery schedule: daily run at 08:00 in TIMEZONE
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Database
POSTGRES_DB=jobhunter
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=jobhunter
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://jobhunter:jobhunter@postgres:5432/jobhunter

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Scraping
SOURCES=github_backendbr,programathor,linkedin
JOB_SEARCH_QUERY=python backend
JOB_SEARCH_LOCATION=Brazil
MAX_JOBS_PER_SOURCE=30
PLAYWRIGHT_TIMEOUT_MS=30000
GITHUB_SINCE_DAYS=14
GITHUB_TOKEN=
SCRAPER_ARTIFACTS_DIR=logs/artifacts
ENABLE_PLAYWRIGHT_TRACING=false
RESPECT_ROBOTS_TXT=false
SCRAPER_RATE_LIMIT_SECONDS=1.0

# Scoring
DESIRED_STACK=Python,Django,FastAPI,PostgreSQL,Docker,AWS,Celery,Redis,SQLAlchemy
MUST_HAVE_STACK=Python,PostgreSQL
NICE_TO_HAVE_STACK=FastAPI,Docker,AWS,Redis,Celery
NEGATIVE_KEYWORDS=estágio,frontend only,presencial obrigatório
PREFERRED_LOCATION=remote,brazil
REMOTE_ONLY=false
DESIRED_SENIORITY=senior
MIN_SCORE_TO_NOTIFY=50

# Telegram
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML
SEND_EMPTY_REPORT=false

# E-mail notification (optional)
ENABLE_EMAIL=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Flower
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=jobhunter:jobhunter

# Test database
DATABASE_URL_TEST=postgresql+psycopg://jobhunter:jobhunter@localhost:5432/jobhunter_test

# API
API_PORT=8000
