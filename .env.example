# Application
APP_ENV=local
LOG_LEVEL=INFO
LOG_DIR=logs
TIMEZONE=America/Sao_Paulo

# Celery schedule: daily run at 08:00 in TIMEZONE
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Database
POSTGRES_DB=jobhunter
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=jobhunter
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://jobhunter:jobhunter@postgres:5432/jobhunter

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Scraping
SOURCES=github_backendbr,programathor,linkedin
JOB_SEARCH_QUERY=python backend
JOB_SEARCH_LOCATION=Brazil
MAX_JOBS_PER_SOURCE=30
PLAYWRIGHT_TIMEOUT_MS=30000
GITHUB_SINCE_DAYS=14
GITHUB_TOKEN=

# Scoring
DESIRED_STACK=Python,Django,FastAPI,PostgreSQL,Docker,AWS,Celery,Redis,SQLAlchemy
DESIRED_SENIORITY=senior
MIN_SCORE_TO_NOTIFY=1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# E-mail notification (optional)
ENABLE_EMAIL=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Flower
FLOWER_PORT=5555
